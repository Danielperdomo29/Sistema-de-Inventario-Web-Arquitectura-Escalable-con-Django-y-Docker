#  Última actualización: 2026-05-09
# ============================================================

# ----------------------------------------------------------
# 🐍 Python / Django
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
*.sql
*.dump

# Migraciones compiladas
**/migrations/*.pyc

# Archivos de media subidos por usuarios (opcional, descomentar si aplica)
# media/

# Media DIAN (facturas generadas)
media/dian/
media/fiscal/
media/receipts/

# ----------------------------------------------------------
# 🔐 SEGURIDAD - CRÍTICO (NO MODIFICAR)
# ----------------------------------------------------------
# Variables de entorno y secretos
.env
.env.local
.env.*.local
*.env
!.env.example

# Archivos de secretos Docker
docker-compose.override.yml
*.secret
*.key
*.pem
*.crt
*.p12

# Tokens y credenciales
**/credentials/
**/secrets/
*.credentials
token.json
client_secret*.json

# ----------------------------------------------------------
# 🐳 Docker - Volúmenes y datos persistentes
# ----------------------------------------------------------
.docker/mysql/database/*
.docker/server/log/*
.docker/nginx/log/*
mysql_data/
redis_data/
postgres_data/
mongo_data/

# Docker override (puede contener secrets locales)
docker-compose.override.yml

# ----------------------------------------------------------
# 🧪 Testing / QA / SAST
# ----------------------------------------------------------
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.pytest_cache/
nosetests.xml

# Reportes de seguridad SAST (contienen rutas locales)
bandit-report.json
bandit_project_high.json
bandit_project_medium.json
bandit_*.json
semgrep-results.json

# ----------------------------------------------------------
# 🛠️ IDEs y Editores
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

